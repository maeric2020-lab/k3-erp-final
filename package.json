{
  "name": "k3-erp",
  "version": "0.1.0",
  "private": true,
  "description": "K3 ERP — Maintenance Department Management System for K. Three Co. for Gen. Trad. & Cont.",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter @k3/web dev",
    "build": "pnpm --filter @k3/web build",
    "start": "pnpm --filter @k3/web start",
    "lint": "pnpm --filter @k3/web lint",
    "typecheck": "pnpm -r typecheck",
    "verify": "pnpm typecheck && pnpm lint && pnpm build && node scripts/verify-no-duplicates.mjs",
    "verify:quick": "pnpm typecheck && node scripts/verify-no-duplicates.mjs",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:gen-types": "supabase gen types typescript --local > packages/shared-types/src/database.types.ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "supabase": "^1.150.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
