# =============================================================================
# K3 ERP — متغيرات البيئة
# =============================================================================
# انسخ هذا الملف إلى .env.local وعبّئ القيم الفعلية.
# في Vercel، أضف هذه المتغيرات في Project Settings → Environment Variables.

# -----------------------------------------------------------------------------
# Supabase — متغيرات إلزامية
# -----------------------------------------------------------------------------

# الرابط العام لمشروعك على Supabase
# تجد هذا في: Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# المفتاح العام (anon key) — آمن للنشر في bundle المتصفح
# Supabase Dashboard → Project Settings → API → anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key

# مفتاح service_role — **سرّي. الخادم فقط. لا تكشفه أبداً.**
# Supabase Dashboard → Project Settings → API → service_role key
# يستخدمه النظام لـ: bootstrap أول مدير، دعوة المستخدمين، إدارة storage
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-key

# -----------------------------------------------------------------------------
# اختياري — رابط التطبيق
# -----------------------------------------------------------------------------
# يُستخدَم في الإيميلات والروابط المطلقة. اتركه فارغاً محلياً.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# -----------------------------------------------------------------------------
# اختياري — Sentry (مراقبة الأخطاء)
# -----------------------------------------------------------------------------
# اشترك مجاناً في sentry.io، أنشئ مشروع Next.js، انسخ DSN
SENTRY_DSN=

# -----------------------------------------------------------------------------
# اختياري — Upstash Redis (rate limiting موزَّع)
# -----------------------------------------------------------------------------
# بدونها سيستخدم النظام rate limiting في الذاكرة (يكفي لنسخة Vercel واحدة)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
